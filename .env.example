# ═══════════════════════════════════════════════════════════════
# TCS ION Manpower Portal — Environment Variables
# Copy to .env.local for local dev, or add to Vercel Dashboard
# for production/preview deployments.
# ═══════════════════════════════════════════════════════════════

# ── Supabase (REQUIRED)
# Get from: https://supabase.com/dashboard → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── App URL (REQUIRED)
# For local dev: http://localhost:3005
# For Vercel: auto-detected via VERCEL_URL — set this only if using a custom domain
NEXT_PUBLIC_APP_URL=http://localhost:3005

# ── Google Gemini AI (REQUIRED)
# Get free key from: https://aistudio.google.com → API Keys
GOOGLE_GEMINI_API_KEY=your-gemini-api-key

# ── Resend Email (OPTIONAL — needed for email features)
# Sign up at: https://resend.com → API Keys → Create Key
# Free plan: 3000 emails/month, use onboarding@resend.dev as sender
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=onboarding@resend.dev

# ── Upstash Redis (OPTIONAL — rate limiting falls back to in-memory without this)
# Sign up at: https://upstash.com → Create Redis Database
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ── Encryption (REQUIRED)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=generate-a-64-char-hex-string
SEARCH_HASH_SALT=generate-a-random-string

# ── Sentry Error Monitoring (OPTIONAL)
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# ── Local Development Only (DO NOT set on Vercel)
# NODE_OPTIONS=--dns-result-order=ipv4first
